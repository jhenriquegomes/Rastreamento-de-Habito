rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: habits
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required, 1-100 chars)
    //   - color: string (optional)
    //   - userId: string (required, immutable)
    //   - createdAt: timestamp (required, immutable)
    //   - reminderEnabled: boolean (optional)
    //   - reminderTime: string (optional, HH:mm)
    //   - reminderDays: list (optional, 0-6)
    //
    // Collection: logs
    // Document ID: habitId_date (e.g., "habit123_2026-03-26")
    // Fields:
    //   - habitId: string (required, immutable)
    //   - date: string (required, format YYYY-MM-DD, immutable)
    //   - completed: boolean (required)
    //   - userId: string (required, immutable)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "henrique.gomes50223@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidDateString(dateStr) {
      return dateStr is string && dateStr.matches("^\\d{4}-\\d{2}-\\d{2}$");
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidHabit(data) {
      return hasRequiredFields(['name', 'userId', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.userId is string &&
             data.createdAt is timestamp &&
             (!('reminderEnabled' in data) || data.reminderEnabled is bool) &&
             (!('reminderTime' in data) || (data.reminderTime is string && data.reminderTime.matches("^\\d{2}:\\d{2}$"))) &&
             (!('reminderDays' in data) || (data.reminderDays is list && data.reminderDays.size() <= 7));
    }

    function isValidLog(data) {
      return hasRequiredFields(['habitId', 'date', 'completed', 'userId']) &&
             data.habitId is string &&
             isValidDateString(data.date) &&
             data.completed is bool &&
             data.userId is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /habits/{habitId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isAuthenticated() && 
                      isValidHabit(request.resource.data) && 
                      isOwner(request.resource.data.userId);
      allow update: if isOwner(resource.data.userId) && 
                      isValidHabit(request.resource.data) && 
                      request.resource.data.userId == resource.data.userId &&
                      request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isOwner(resource.data.userId);
    }

    match /logs/{logId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isAuthenticated() && 
                      isValidLog(request.resource.data) && 
                      isOwner(request.resource.data.userId);
      allow update: if isOwner(resource.data.userId) && 
                      isValidLog(request.resource.data) && 
                      request.resource.data.userId == resource.data.userId &&
                      request.resource.data.habitId == resource.data.habitId &&
                      request.resource.data.date == resource.data.date;
      allow delete: if isOwner(resource.data.userId);
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }
  }
}
